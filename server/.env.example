# TollGate server — copy to .env and fill in.

# HTTP port
PORT=8787

# development | production  (dev enables the "X-PAYMENT: dev-bypass" header)
NODE_ENV=development

# Comma-separated allowed origins for CORS, or "*"
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Where x402 payments should be sent (the provider/settlement wallet shown in challenges).
# Demo value below — replace with a real testnet address per workspace if you wire real settlement.
X402_PAYOUT_ADDRESS=0x0000000000000000000000000000000000000000

# Default settlement network + asset advertised in payment challenges.
X402_NETWORK=base-sepolia
X402_ASSET=USDC

# ── Server-side autonomous on-chain signing ─────────────────────────────────
# When set, every x402 payment is autonomously recorded on Mantle (AgentVault +
# AgentCreditRegistry) and optionally on 0G (AgentReceiptRegistry).
# Use a dedicated hot wallet with a small operating balance (e.g. 0.01 MNT).
# Logs: [chain-signer] lines in server stdout show tx hashes after each payment.
MANTLE_PRIVATE_KEY=
MANTLE_RPC_URL=https://rpc.mantle.xyz
# Deployed AgentVault (recordDecision audit trail)
MANTLE_VAULT_ADDRESS=0xCbBcFc657787Fef2702ae6E35CA5a809a68480da
# Deployed AgentCreditRegistry (recordPayment credit scoring)
MANTLE_CREDIT_ADDRESS=0xA8FdDb9F6f54Fbf127cb8c71049cB1e19f5836F9
# Optional 0G registry for cross-chain receipt anchoring (leave blank to skip)
OG_REGISTRY_ADDRESS=

# ── 0G Storage (server-side real upload) ────────────────────────────────────
# Funded 0G wallet private key → POST /api/og/upload computes a real 0G Merkle
# root and submits to the FixedPriceFlow contract. Unset → SHA-256 fallback.
OG_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai

# ── Base Sepolia USDC settlement verification ───────────────────────────────
# When an agent pays with a real Base Sepolia USDC tx, the server verifies the
# on-chain ERC-20 Transfer log before unlocking the resource. Unset → accept
# any proof with a txHash on faith (still replay-protected by challenge system).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# USDC on Base Sepolia (official testnet token)
USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ── 0G Compute (server-side real inference) ─────────────────────────────────
# 1) npm i @0gfoundation/0g-compute-ts-sdk   (in server/)
# 2) fund the ledger once with a 0G wallet that holds OG:  node scripts/og-compute-fund.mjs
#    (≥3 OG deposited + 1 OG locked to the provider; faucet.0g.ai for Galileo testnet)
# 3) set OG_COMPUTE_PRIVATE_KEY (same wallet) here + on Render.
# Unset → POST /api/og/compute returns 503 compute_not_configured and the frontend
# uses its deterministic demo fallback (UI shows a 🟡 Demo badge instead of 🟢 Live).
OG_COMPUTE_PRIVATE_KEY=
# RPC for 0G Compute. Default = Galileo testnet (where faucet.0g.ai works); use https://evmrpc.0g.ai for mainnet.
OG_COMPUTE_RPC=https://evmrpc-testnet.0g.ai
# Provider address — list current ones with `node scripts/og-compute-fund.mjs --list` or compute-marketplace.0g.ai
OG_COMPUTE_PROVIDER=0xa48f01287233509FD694a22Bf840225062E67836
