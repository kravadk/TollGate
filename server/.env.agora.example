# ArcMind CopyGuard backend production example.
# Copy values into your deployment secret manager. Do not commit real secrets.

NODE_ENV=production
PORT=8787
CORS_ORIGIN=https://<frontend-domain>
SERVER_URL=https://<backend-domain>

X402_PAYOUT_ADDRESS=0x<funded-arc-wallet>
X402_NETWORK=arc-testnet
X402_ASSET=USDC

ARC_RPC_URL=https://<arc-rpc>
ARC_PRIVATE_KEY=<dedicated-funded-hot-wallet-private-key>
ARC_AGENT_ID=0x<bytes32-agent-id>
ARC_AGENT_REGISTER_TX=0x<registration-tx-hash>
ARC_AGENT_INTERVAL_MS=1800000
ARC_ADMIN_TOKEN=<random-secret-for-manual-agent-tick>

# Optional live signal-source radar. Leave unset to show honest needs-key/watchlist states.
APIFY_TOKEN=<optional-apify-token>
ARC_SIGNAL_SOURCE_MODE=watchlist
COINGECKO_API_KEY=<optional-paid-or-demo-key>
PINATA_JWT=<optional-pinata-jwt-for-trace-json>
TELEGRAM_BOT_TOKEN=<optional-telegram-bot-token>
TELEGRAM_CHAT_ID=<optional-telegram-chat-id>

# Optional real copy-leader scoring. Leave unset unless this is a real URL
# with sourced metrics. When unset, ArcMind runs No-Nansen SignalGuard mode
# and never displays synthetic leaders. The endpoint must return either an
# array or { "leaders": [...] } with id/name, winRatePct, sharpe,
# maxDrawdownPct, recentPnlPct, liquidityUsd, recentLosses, and source proof.
# ARC_LEADER_FEED_URL=https://<your-leader-feed-json>

VITE_ARC_REGISTRY_ADDRESS=0x<ArcMindRegistry-address>
VITE_ARC_ESCROW_ADDRESS=0x<CopyTradeEscrow-address>

ARC_TRACTION_FILE=/persistent/data/arc-traction.jsonl
DB_PATH=/persistent/data/receipts.db
