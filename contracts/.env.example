# contracts/.env — chain config for deploying the 0G pieces. Copy to contracts/.env.
# .env is git-ignored; never commit a private key.

# ── EVM RPC ───────────────────────────────────────────────────────────────────
# 0G mainnet RPC (leave blank to fall back to the hardhat.config default).
OG_RPC_URL=
# 0G chain id for the `og` network. Leave blank to let the node report it.
OG_CHAIN_ID=

# 0G Galileo testnet — for a dry run before mainnet.
OG_TESTNET_RPC_URL=https://evmrpc-testnet.0g.ai
OG_TESTNET_CHAIN_ID=16601

# Funded deployer key (mainnet OR testnet, matching the --network you use).
# Example placeholder — replace with your own, keep it out of git.
OG_PRIVATE_KEY=0xYOUR_FUNDED_PRIVATE_KEY

# Block explorer base URL — used only to print clickable links after deploy.
OG_EXPLORER_URL=https://chainscan-galileo.0g.ai

# ── 0G Storage (only needed for `npm run upload:0g`) ──────────────────────────
# Storage node RPC + indexer endpoint. See 0G docs for current endpoints.
OG_STORAGE_RPC=
OG_STORAGE_INDEXER=

# ── Mantle (for `npm run deploy:mantle` / `deploy:mantle-sepolia`) ────────────
# Funded deployer key on Mantle (mainnet 5000 or Sepolia 5003). Placeholder — replace.
MANTLE_PRIVATE_KEY=0xYOUR_FUNDED_MANTLE_PRIVATE_KEY
# RPCs — leave blank to use the hardhat.config defaults (rpc.mantle.xyz / rpc.sepolia.mantle.xyz).
MANTLE_RPC_URL=
MANTLE_SEPOLIA_RPC_URL=
# Explorer base URL for the printed links — defaults to explorer.mantle.xyz / explorer.sepolia.mantle.xyz.
MANTLE_EXPLORER_URL=
# AgentVault yield token. Leave blank → mETH on mainnet (0xcDA86A2…0bb0), zero address on testnet.
MANTLE_METH_ADDRESS=

# ── Arbitrum (for `npm run deploy:arb` / `deploy:arb-one` / `deploy:orbit`) ───
# Funded deployer key on Arbitrum (One 42161 or Sepolia 421614 — gas is ETH). Placeholder — replace.
ARBITRUM_PRIVATE_KEY=0xYOUR_FUNDED_ARBITRUM_PRIVATE_KEY
# RPCs — leave blank to use the hardhat.config defaults (arb1.arbitrum.io/rpc / sepolia-rollup.arbitrum.io/rpc).
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
# Arbitrum Orbit chain (e.g. Robinhood Chain) — fill these to deploy with `npm run deploy:orbit`.
ORBIT_RPC_URL=
ORBIT_CHAIN_ID=
ORBIT_EXPLORER_URL=

# ── QIE testnet (for `npm run deploy:qie`) ────────────────────────────────────
QIE_RPC_URL=https://rpc1testnet.qie.digital/
QIE_PRIVATE_KEY=
QIE_CHECKOUT_ADDRESS=
QIE_PASS_ADDRESS=
