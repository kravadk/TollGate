# TollGate — frontend env. Copy to .env.local (Vite picks it up).

# Base URL of the TollGate server (../server). In dev it defaults to
# http://localhost:8787 even if unset. Point it at the deployed server in prod,
# e.g. https://tollgate-server.onrender.com — must be reachable by the
# browser and have CORS_ORIGIN set to this site's origin.
# Set to an empty string to hard-disable the Live Gateway panel (simulation only).
VITE_API_BASE=http://localhost:8787

# ── 0G on-chain (optional) ───────────────────────────────────────────────────
# Deploy contracts/AgentReceiptRegistry.sol first:  cd contracts && npm run deploy:0g
# With VITE_0G_REGISTRY_ADDRESS set, the 0G workspace's "Pin to 0G Storage" and
# "Run an inference job" widgets gain an "Anchor on 0G" action that sends a real
# record(...) tx from the connected wallet (which must be on the 0G chain) and links
# the receipt to a 0G Explorer transaction. Unset → the app still works, no anchor button.
# Live demo deploys it to 0G mainnet: 0xF4BFd93061B160Fa376c7F66De207a00225B4e70
VITE_0G_REGISTRY_ADDRESS=
# 0G chain id MetaMask uses (hex or decimal). 0x4115 = 16661 (0G mainnet); 0x40da = 16602 (Galileo testnet).
VITE_0G_CHAIN_ID=0x4115
# Block explorer base URL for the links (no trailing slash).
VITE_0G_EXPLORER=https://chainscan.0g.ai
# 0G Storage indexer HTTP endpoint. Set it → the Pin widget shows real Merkle roots;
# unset → it falls back to a deterministic sha256-derived root, clearly flagged "simulated".
VITE_0G_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai

# ── Mantle on-chain (optional) ───────────────────────────────────────────────
# Deploy contracts/AgentIdentityRegistry.sol + AgentVault.sol first:
#   cd contracts && npm run deploy:mantle           (Mantle mainnet 5000)
#   # or: npm run deploy:mantle-sepolia             (Mantle Sepolia 5003)
# With these set, the Mantle workspace's Agents tab gains: "ERC-8004 agent identity"
# (registers a real identity NFT) and "AgentVault" (real deposit / deployToYield /
# recordDecision txs). Unset → those panels show a "scaffolded, one command from live"
# note and the rest of the Mantle workspace runs in simulation. Nothing breaks either way.
VITE_MANTLE_IDENTITY_ADDRESS=
VITE_MANTLE_VAULT_ADDRESS=
# Mantle chain id MetaMask must be on (hex or decimal). 0x1388 = 5000 (mainnet); 0x138b = 5003 (Sepolia).
VITE_MANTLE_CHAIN_ID=0x1388
# Block explorer base URL for the links (no trailing slash).
VITE_MANTLE_EXPLORER=https://explorer.mantle.xyz

# ── Arbitrum on-chain (optional) ─────────────────────────────────────────────
# Deploy contracts/AgentEscrow.sol first:  cd contracts && npm run deploy:arb   (Arbitrum Sepolia)
# With this set, the Arbitrum workspace's "Escrow" tab gains a real "AgentEscrow" panel
# (open / release / refund / cancel — native-ETH escrow, real txs from the connected wallet).
# Unset → that tab keeps the simulated escrow only. Nothing breaks either way.
VITE_ARBITRUM_ESCROW_ADDRESS=
# Arbitrum chain id MetaMask must be on. 0x66eee = 421614 (Sepolia); 0xa4b1 = 42161 (Arbitrum One).
VITE_ARBITRUM_CHAIN_ID=0x66eee
# Block explorer base URL for the links (no trailing slash).
VITE_ARBITRUM_EXPLORER=https://sepolia.arbiscan.io
